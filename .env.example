# RAG-Lab Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit the '.env' file to version control.

# ==============================================================================
# Cloud Architecture Configuration
# ==============================================================================
# Dynamic switch to toggle the cloud footprint.
# Options: "gcp", "aws", or "local" (offline hashed embeddings + extractive LLM)
CLOUD_PROVIDER=local

# Vector store backend: "pgvector" (requires docker-compose up) or "local"
# (numpy with JSON persistence, no infrastructure needed)
VECTOR_BACKEND=local

# ==============================================================================
# GCP Credentials & Configuration
# ==============================================================================
# Your GCP Project ID (e.g. my-gcp-project-123)
GCP_PROJECT_ID=your-gcp-project-id
# Region for Vertex AI (e.g. us-central1)
GCP_LOCATION=us-central1
# Google Cloud Storage bucket name for raw SEC documents
GCS_BUCKET_NAME=your-gcs-bucket-name
# Models (start cheap; change without code edits). Flash is low-cost.
GCP_LLM_MODEL=gemini-2.5-flash
GCP_EMBED_MODEL=gemini-embedding-2
# Path to GCP Service Account Key file (optional if using local gcloud auth ADC)
GOOGLE_APPLICATION_CREDENTIALS=

# ==============================================================================
# AWS Credentials & Configuration
# ==============================================================================
# AWS Access Key ID
AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS Session Token (if using temporary credentials)
AWS_SESSION_TOKEN=
# Target AWS Region (e.g. us-east-1, us-west-2)
AWS_REGION=us-east-1
# AWS S3 bucket name for raw SEC documents
S3_BUCKET_NAME=your-s3-bucket-name

# ==============================================================================
# Database Configuration (PostgreSQL + pgvector)
# ==============================================================================
# Local or remote PostgreSQL instance details
# Standard Postgres image: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://fund_manager:CHANGE_ME_LOCAL_DEV@localhost:5432/rag_lab

# ==============================================================================
# Additional Optional API Keys
# ==============================================================================
# Cohere API Key (used for BGE / Cohere reranking)
COHERE_API_KEY=
# OpenAI API Key (optional fallback or for comparison)
OPENAI_API_KEY=
