# Raw ingested documents / SEC filings / personal finance data.
# Everything under data/ is ignored so real bank statements never get committed,
# EXCEPT the synthetic demo statement (fake data, safe to publish + needed by tests).
sec_edgar_filings/
data/*
!data/finance/
data/finance/*
!data/finance/sample_transactions.csv

