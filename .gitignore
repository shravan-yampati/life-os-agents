.pytest_cache/
.coverage
htmlcov/
evals/results/*.json
evals/results/*.csv
evals/results/*.html

# rag-lab runtime artifacts (local vector store, local storage)
.raglab/

# Personal project brief (contains infra IPs / account identifiers)
claude_project_brief.md

# Zipped artifacts (design docs are committed as .md)
*.zip

# Grill Me brainstorms — deeply personal real-life values, never publish
brainstorms/
